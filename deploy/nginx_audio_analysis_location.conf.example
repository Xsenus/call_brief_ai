# Add this location block inside the existing server block for ai.irbistech.com.
# It proxies the call viewer pages and the HTML5 audio stream to the local daemon.

location /audio/analysis/ {
    proxy_pass http://127.0.0.1:8080/audio/analysis/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
}
